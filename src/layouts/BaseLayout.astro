---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

const {
    title = "Altralight",
    description = "We build games, tools, and experiments like Modern Football, Stygian, and Field Continuum.",
    bodyClass = "",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
        (() => {
            const storageKey = "altralight-theme";
            const root = document.documentElement;
            let theme = "dark";

            try {
                const stored = window.localStorage.getItem(storageKey);
                if (stored === "light" || stored === "dark") {
                    theme = stored;
                } else if (window.matchMedia("(prefers-color-scheme: light)").matches) {
                    theme = "light";
                }
            } catch {
                theme = "dark";
            }

            root.dataset.theme = theme;
        })();
    </script>
</head>
<body class={bodyClass}>
    <slot />
    <footer class="site-credit" aria-label="Site credit">
        <p>Built with help from Codex.</p>
    </footer>
    <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false">
        Light Mode
    </button>
    <script is:inline>
        (() => {
            const storageKey = "altralight-theme";
            const root = document.documentElement;
            const toggle = document.querySelector("[data-theme-toggle]");

            if (!toggle) {
                return;
            }

            const syncToggle = () => {
                const isLight = root.dataset.theme === "light";
                toggle.textContent = isLight ? "Dark Mode" : "Light Mode";
                toggle.setAttribute("aria-pressed", String(isLight));
                toggle.setAttribute("aria-label", isLight ? "Switch to dark mode" : "Switch to light mode");
            };

            toggle.addEventListener("click", () => {
                const nextTheme = root.dataset.theme === "light" ? "dark" : "light";
                root.dataset.theme = nextTheme;

                try {
                    window.localStorage.setItem(storageKey, nextTheme);
                } catch {
                    // If storage is blocked, the toggle can still work for this page load.
                }

                syncToggle();
            });

            syncToggle();
        })();
    </script>
</body>
</html>
