---
import { progressPosts } from "../data/progressPosts";

const featuredPosts = [...progressPosts].sort((a, b) => b.date.localeCompare(a.date)).slice(0, 3);
---

<div class="site-shell">
    <header class="site-header">
        <a class="brand" href="/" aria-label="Altralight home">
            <img class="brand-mark" src="/brand/altralight-logo.png" alt="" width="500" height="500" />
            <span class="brand-wording">
                <span class="brand-name">Altralight</span>
                <span class="brand-subtitle">Systems, games, and tools we enjoy building</span>
            </span>
        </a>
        <nav class="site-nav" aria-label="Primary">
            <a href="#projects">Projects</a>
            <a href="#work">Work</a>
            <a href="/blog/">Blog</a>
        </nav>
    </header>

    <main>
        <section class="hero" id="top">
            <div class="hero-copy" data-intro="copy">
                <div class="hero-ribbon">
                    <span>Work signal online</span>
                    <span>Progress tracked in public</span>
                </div>
                <div class="hero-status-band" aria-label="Visual cues">
                    <span class="status-chip"><span class="chip-orb chip-orb-aqua"></span>Glass</span>
                    <span class="status-chip"><span class="chip-orb chip-orb-sky"></span>Waterline</span>
                    <span class="status-chip"><span class="chip-orb chip-orb-mint"></span>Air</span>
                </div>
                <p class="eyebrow">Building in public, as usual.</p>
                <h1>We build games, tools, and experiments we wish already existed.</h1>
                <p class="hero-text">
                    We are building Modern Football, Stygian, Field Continuum, and Qit. Some of it is game work, some of it is research, and all of it
                    is active right now.
                </p>
                <div class="hero-actions">
                    <a class="button button-primary" href="#projects">See the work</a>
                    <a class="button button-secondary" href="/blog/">Read progress posts</a>
                </div>
                <div class="hero-links" aria-label="Studio links">
                    <a href="/stygian/">Stygian runtime</a>
                    <a href="/continuum/">Field Continuum</a>
                    <a href="/qit/">Qit VCS</a>
                    <a href="/modern-football/">Football build</a>
                    <a href="/blog/">Progress blog</a>
                </div>
                <div class="hero-console" aria-label="Studio notes">
                    <article>
                        <span class="console-label">THIS WEEK</span>
                        <p>Less marketing voice, more field notes. Better rhythm, clearer updates.</p>
                    </article>
                    <article>
                        <span class="console-label">WHAT TO WATCH</span>
                        <p>All four tracks are moving. We post updates as they happen.</p>
                    </article>
                </div>
                <ul class="hero-stats" aria-label="Studio highlights">
                    <li><span class="stat-value">04</span><span class="stat-label">Active tracks</span></li>
                    <li><span class="stat-value">{progressPosts.length}</span><span class="stat-label">Progress posts</span></li>
                    <li><span class="stat-value">100%</span><span class="stat-label">Built in public</span></li>
                </ul>
            </div>

            <div class="hero-art" data-intro="art">
                <div class="hero-stage" data-stage>
                    <div class="hero-cover-card" aria-hidden="true">
                        <img class="hero-cover" src="/brand/altralight-center.png" alt="" width="1000" height="1000" />
                    </div>
                    <div class="hero-grid"></div>
                    <div class="hero-beam"></div>
                    <div class="aero-bubble bubble-one"></div>
                    <div class="aero-bubble bubble-two"></div>
                    <div class="aero-bubble bubble-three"></div>
                    <div class="aero-wave"></div>
                    <div class="hero-dock" aria-hidden="true">
                        <span class="dock-pill"><span class="dock-core"></span>New notes land in the blog</span>
                    </div>
                </div>

                <div class="hero-panel hero-panel-main">
                    <span class="panel-label">ALTRALIGHT / SIGNAL</span>
                    <p>Make useful things. Keep them fast. Tell the truth.</p>
                </div>
                <div class="hero-panel hero-panel-side">
                    <span class="panel-label">CURRENT MODE</span>
                    <p>If it changed, it goes in the blog. If it broke, that goes in too.</p>
                </div>
                <div class="hero-sticker hero-sticker-top">Still moving, still public</div>
            </div>
        </section>

        <section class="marquee" aria-label="Studio themes">
            <div class="marquee-track">
                <span>Altralight</span>
                <span>Game tools</span>
                <span>Sports weirdness</span>
                <span>Field Continuum</span>
                <span>Qit VCS</span>
                <span>Stygian runtime</span>
                <span>Progress posts</span>
                <span>Altralight</span>
                <span>Game tools</span>
                <span>Sports weirdness</span>
                <span>Field Continuum</span>
                <span>Qit VCS</span>
                <span>Stygian runtime</span>
                <span>Progress posts</span>
            </div>
        </section>

        <section class="manifesto panel" id="work">
            <div class="section-heading">
                <p class="section-kicker">Work Direction</p>
                <h2>Builds, research, and experiments all share one workshop.</h2>
            </div>
            <div class="warning-strip">
                <span>Modern Football in active build</span>
                <span>Stygian for UI and tools</span>
                <span>Field Continuum in progress</span>
                <span>Qit for version control research</span>
                <span>Progress logged publicly</span>
            </div>
            <div class="manifesto-grid">
                <article>
                    <h3>Modern Football is the game we are pushing hardest</h3>
                    <p>The rest of the stack supports that game while still being useful for future projects.</p>
                </article>
                <article>
                    <h3>Core systems have names and pages</h3>
                    <p>Stygian, Field Continuum, and Qit are active tracks with their own direction and notes.</p>
                </article>
                <article>
                    <h3>Blog updates keep it honest</h3>
                    <p>Progress posts cover what changed, what worked, and what still needs more thought.</p>
                </article>
            </div>
        </section>

        <section class="projects panel" id="projects">
            <div class="section-heading">
                <p class="section-kicker">Projects</p>
                <h2>The current lineup.</h2>
            </div>
            <div class="project-grid">
                <article class="project-card project-stygian-card">
                    <div class="stygian-card-preview" aria-hidden="true">
                        <div class="stygian-card-bar">
                            <span class="stygian-card-url">fieldengine.space</span>
                        </div>
                        <div class="stygian-card-shell">
                            <div class="stygian-card-rail">
                                <span>H</span>
                                <span>B</span>
                                <span>D</span>
                            </div>
                            <div class="stygian-card-surface"></div>
                        </div>
                    </div>
                    <div class="card-topline">
                        <span class="card-tag">Core Runtime</span>
                        <span class="card-index">01</span>
                    </div>
                    <h3>Stygian</h3>
                    <p>A GPU-accelerated C23 UI and tooling runtime focused on responsive desktop apps and steady frame behavior.</p>
                    <ul class="card-specs" aria-label="Stygian highlights">
                        <li>SDF-first rendering</li>
                        <li>Deterministic commit</li>
                        <li>Idle frame skip path</li>
                    </ul>
                    <a class="card-link" href="/stygian/">Open Stygian</a>
                </article>
                <article class="project-card project-grid-card">
                    <div class="card-orb card-orb-grid" aria-hidden="true"></div>
                    <div class="card-topline">
                        <span class="card-tag">Community Lab</span>
                        <span class="card-index">02</span>
                    </div>
                    <h3>Grid</h3>
                    <p>A customized engine playground built on Godot for workflow testing, tooling ideas, and practical experiments.</p>
                    <ul class="card-specs" aria-label="Grid highlights">
                        <li>Godot-based core</li>
                        <li>Tooling experiments</li>
                        <li>Editor workflow cleanup</li>
                    </ul>
                    <a class="card-link" href="/grid/">Open Grid</a>
                </article>
                <article class="project-card project-continuum-card">
                    <div class="card-orb card-orb-continuum" aria-hidden="true"></div>
                    <div class="card-topline">
                        <span class="card-tag">Field Continuum</span>
                        <span class="card-index">03</span>
                    </div>
                    <h3>Field Continuum</h3>
                    <p>A custom field continuum in active development for Modern Football and the deeper simulation work behind it.</p>
                    <ul class="card-specs" aria-label="Field Continuum highlights">
                        <li>Field in active build</li>
                        <li>Simulation-first</li>
                        <li>Designed with Stygian + Scaffold</li>
                    </ul>
                    <a class="card-link" href="/continuum/">Open Field Continuum</a>
                </article>
                <article class="project-card project-qit-card">
                    <div class="card-orb card-orb-qit" aria-hidden="true"></div>
                    <div class="card-topline">
                        <span class="card-tag">Version Control</span>
                        <span class="card-index">04</span>
                    </div>
                    <h3>Qit</h3>
                    <p>Quick Immutable Tree. A VCS project focused on safety, speed, compression, and better metadata handling.</p>
                    <ul class="card-specs" aria-label="Qit highlights">
                        <li>Immutable tree model</li>
                        <li>C++23 implementation</li>
                        <li>Git-adjacent problem space</li>
                    </ul>
                    <a class="card-link" href="/qit/">Open Qit</a>
                </article>
                <article class="project-card project-football-card">
                    <div class="project-wave" aria-hidden="true"></div>
                    <div class="card-orb card-orb-football" aria-hidden="true"></div>
                    <div class="card-topline">
                        <span class="card-tag">In Progress</span>
                        <span class="card-index">05</span>
                    </div>
                    <h3>Modern Football</h3>
                    <p>A football game built from scratch. Tactical, reactive, and focused on decision-making that feels true to the sport.</p>
                    <ul class="card-specs" aria-label="Modern Football highlights">
                        <li>Tactical simulation</li>
                        <li>Fresh AI assumptions</li>
                        <li>No sports-game autopilot</li>
                    </ul>
                    <a class="card-link" href="/modern-football/">Open Modern Football</a>
                </article>
            </div>
            <div class="project-strip">
                <span>Built in public</span>
                <span>No investors in the room</span>
                <span>Fast by default</span>
                <span>Weird on purpose</span>
            </div>
        </section>

        <section class="signal-yard panel" id="signal-yard">
            <div class="section-heading">
                <p class="section-kicker">Progress Blog</p>
                <h2>Recent build updates.</h2>
            </div>
            <div class="yard-copy">
                <p>Posts land as work lands. The homepage stays focused while the blog carries the day-to-day details.</p>
            </div>
            <div class="blog-preview-grid">
                {featuredPosts.map((post) => (
                    <article class="blog-preview-card">
                        <p class="section-kicker">{post.date}</p>
                        <h3>{post.title}</h3>
                        <p>{post.summary}</p>
                        <a class="card-link" href={post.href}>Read post</a>
                    </article>
                ))}
                <div class="blog-preview-card blog-preview-cta">
                    <p class="section-kicker">Need older updates?</p>
                    <h3>Read the full progress feed.</h3>
                    <p>The blog is our running changelog across games, tooling, research, and field work.</p>
                    <a class="button button-secondary" href="/blog/">Go to Blog</a>
                </div>
            </div>
        </section>
    </main>

    <footer class="site-footer">
        <p>We build Modern Football, Stygian, Field Continuum, Qit, and whatever comes next.</p>
    </footer>
</div>

<script>
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const runIntroMotion = async () => {
        const { gsap } = await import("gsap");

        gsap.from("[data-intro='copy'] > *", {
            duration: 0.9,
            y: 36,
            opacity: 0,
            ease: "power3.out",
            stagger: 0.08,
            clearProps: "transform,opacity",
        });

        gsap.from("[data-intro='art'] > *", {
            duration: 1.05,
            y: 42,
            opacity: 0,
            ease: "power3.out",
            stagger: 0.1,
            delay: 0.08,
            clearProps: "transform,opacity",
        });
    };

    runIntroMotion();
</script>
